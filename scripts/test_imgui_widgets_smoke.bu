import SDL;
using SDL;
import OpenGl;
using OpenGl;
import ImGui;
using ImGui;

SDL.SetGLVersion(2, 1, SDL_GL_CONTEXT_PROFILE_COMPATIBILITY);
SDL.SetGLAttribute(SDL_GL_DOUBLEBUFFER, 1);
SDL.SetGLAttribute(SDL_GL_DEPTH_SIZE, 24);

if (!SDL.Init("ImGui Widgets Smoke", 960, 540, SDL_WINDOW_OPENGL)) return;
if (!SDL.InitImGui()) return;

var frames = 0;
var name = "Smoke Entity";
var notes = "Multiline ok";
var count = 2;
var enabled = true;
var value = 0.5;
var currentTab = 0;

while (SDL.Running())
{
    frames = frames + 1;
    glClear(GL_COLOR_BUFFER_BIT);

    var w = ImGui.Begin("Widgets Smoke");
    if (w != nil && w)
    {
        ImGui.SetNextItemWidth(180);
        var (changedName, nextName) = ImGui.InputText("Name", name, 128);
        name = nextName;

        ImGui.SetNextItemWidth(120);
        var (changedCount, nextCount) = ImGui.DragInt("Count", count, 1.0, 0, 10, "%d");
        count = nextCount;

        var (changedEnabled, nextEnabled) = ImGui.Checkbox("Enabled", enabled);
        enabled = nextEnabled;

        if (ImGui.BeginTabBar("smoke_tabs", ImGui.TabBarFlags_Reorderable))
        {
            var tabA = ImGui.BeginTabItem("Main", currentTab == 0 ? ImGui.TabItemFlags_SetSelected : ImGui.TabItemFlags_None);
            if (tabA != nil && tabA)
            {
                currentTab = 0;
                var (changedValue, nextValue) = ImGui.SliderFloat("Value", value, 0.0, 1.0, "%.2f");
                value = nextValue;
                ImGui.ProgressBar(value, 0, 0, "progress");
                ImGui.EndTabItem();
            }

            var tabB = ImGui.BeginTabItem("Notes");
            if (tabB != nil && tabB)
            {
                currentTab = 1;
                var (changedNotes, nextNotes) = ImGui.InputTextMultiline("##notes", notes, 0, 90, 256);
                notes = nextNotes;
                ImGui.EndTabItem();
            }

            ImGui.EndTabBar();
        }

        ImGui.BeginDisabled(!enabled);
        if (ImGui.Button("Action", 100, 0)) value = 1.0 - value;
        ImGui.EndDisabled();

        if (ImGui.TreeNode("Tree"))
        {
            ImGui.Bullet();
            ImGui.SameLine();
            ImGui.Text("name=" + name);
            ImGui.TreePop();
        }
    }
    ImGui.End();

    SDL.Flip();
 
}

SDL.Close();
print("IMGUI_WIDGETS_SMOKE_PASS");
